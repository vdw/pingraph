<% content_for :title, "Dashboard" %>

<div class="w-full">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-3xl font-bold text-gray-900">Network Dashboard</h1>
      <p class="text-sm text-gray-500 mt-1">Live latency overview — probed every minute</p>
    </div>
    <%= link_to "Manage Groups", groups_path,
          class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
  </div>

  <% if @groups.empty? %>
    <div class="text-center py-24 bg-white rounded-xl border border-dashed border-gray-300">
      <p class="text-gray-500 text-lg mb-4">No groups yet.</p>
      <%= link_to "Create your first group →", new_group_path,
            class: "inline-block rounded-md bg-indigo-600 px-4 py-2 text-white font-medium hover:bg-indigo-500" %>
    </div>
  <% else %>
    <div class="space-y-8">
      <% @groups.each do |group| %>
        <section>
          <%# Group header %>
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-lg font-semibold text-gray-700 flex items-center gap-2">
              <span class="inline-block w-2 h-2 rounded-full bg-indigo-400"></span>
              <%= group.name %>
              <span class="text-xs font-normal text-gray-400">(<%= pluralize(group.hosts.size, "host") %>)</span>
            </h2>
            <%= link_to "+ Add Host", new_host_path(host: { group_id: group.id }),
                  class: "text-xs text-indigo-600 hover:text-indigo-500 font-medium" %>
          </div>

          <% if group.hosts.empty? %>
            <div class="rounded-lg border border-dashed border-gray-200 py-6 text-center text-gray-400 text-sm bg-white">
              No hosts in this group.
            </div>
          <% else %>
            <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
              <table class="min-w-full divide-y divide-gray-100">
                <thead class="bg-gray-50">
                  <tr>
                    <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider w-8"></th>
                    <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Host</th>
                    <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Address</th>
                    <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Latency</th>
                    <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Packet Loss</th>
                    <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Last Seen</th>
                    <th class="py-3 px-4"></th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  <% group.hosts.each do |host| %>
                    <% ping = @latest_pings[host.id] %>
                    <% status = host.status %>
                    <tr class="hover:bg-gray-50 transition-colors">
                      <td class="py-3 px-4">
                        <span class="block w-3 h-3 rounded-full mx-auto
                          <%= status == :up ? 'bg-green-400' :
                              status == :degraded ? 'bg-yellow-400' :
                              status == :down ? 'bg-red-500' :
                              'bg-gray-300' %>">
                        </span>
                      </td>
                      <td class="py-3 px-4 font-medium text-gray-900">
                        <%= link_to host.name, host_path(host), class: "hover:text-indigo-600" %>
                      </td>
                      <td class="py-3 px-4 text-sm text-gray-500 font-mono"><%= host.address %></td>
                      <td class="py-3 px-4 text-sm text-gray-700">
                        <% if ping&.latency %>
                          <span class="font-semibold"><%= "%.2f" % ping.latency %></span>
                          <span class="text-gray-400 text-xs">ms</span>
                          <% if ping.min_latency && ping.max_latency %>
                            <span class="text-gray-400 text-xs ml-1">
                              (<%= "%.1f" % ping.min_latency %> – <%= "%.1f" % ping.max_latency %>)
                            </span>
                          <% end %>
                        <% else %>
                          <span class="text-gray-400">—</span>
                        <% end %>
                      </td>
                      <td class="py-3 px-4 text-sm">
                        <% if ping %>
                          <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                            <%= ping.packet_loss == 0 ? 'bg-green-50 text-green-700' :
                                ping.packet_loss.to_i < 50 ? 'bg-yellow-50 text-yellow-700' :
                                'bg-red-50 text-red-700' %>">
                            <%= ping.packet_loss %>%
                          </span>
                        <% else %>
                          <span class="text-gray-400">—</span>
                        <% end %>
                      </td>
                      <td class="py-3 px-4 text-xs text-gray-400">
                        <%= ping ? time_ago_in_words(ping.recorded_at) + " ago" : "Never" %>
                      </td>
                      <td class="py-3 px-4 text-right text-sm">
                        <%= link_to "Details →", host_path(host),
                              class: "text-indigo-600 hover:text-indigo-500 font-medium text-xs" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% end %>
        </section>
      <% end %>
    </div>
  <% end %>
</div>
