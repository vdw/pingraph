<% content_for :title, "Edit #{@group.name}" %>

<div class="max-w-xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Edit Group</h1>
    <p class="text-sm text-gray-500 mt-1">
      Editing <span class="font-medium text-gray-700"><%= @group.name %></span>
    </p>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
    <%= render "form", group: @group %>
  </div>

  <div class="mt-4 flex gap-4">
    <%= link_to "← Back to Group", @group, class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
    <%= link_to "All Groups", groups_path, class: "text-sm text-gray-500 hover:text-gray-700 font-medium" %>
  </div>
</div>
