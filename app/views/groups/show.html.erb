<% content_for :title, @group.name %>

<div class="w-full max-w-4xl mx-auto">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @group.name %></h1>
      <p class="text-sm text-gray-400 dark:text-gray-500 mt-0.5"><%= pluralize(@group.hosts.size, "host") %></p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_group_path(@group),
            class: "rounded-md px-3 py-2 text-sm bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 font-medium text-gray-700 dark:text-gray-200" %>
      <%= button_to "Delete", @group, method: :delete,
            class: "rounded-md px-3 py-2 text-sm bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-900/30 text-red-700 dark:text-red-400 font-medium cursor-pointer",
            data: { turbo_confirm: "Delete group \"#{@group.name}\" and all its hosts?" } %>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden mb-4">
    <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center">
      <h2 class="text-sm font-semibold text-gray-600 dark:text-gray-300">Hosts</h2>
      <%= link_to "+ Add Host", new_host_path(host: { group_id: @group.id }),
            class: "text-xs text-indigo-600 hover:text-indigo-500 font-medium" %>
    </div>
    <% if @group.hosts.any? %>
      <ul class="divide-y divide-gray-50 dark:divide-gray-700">
        <% @group.hosts.each do |host| %>
          <li class="flex items-center justify-between px-5 py-3">
            <div>
              <span class="font-medium text-gray-900 dark:text-white"><%= host.name %></span>
              <span class="text-xs text-gray-400 dark:text-gray-500 font-mono ml-2"><%= host.address %></span>
            </div>
            <%= link_to "View", host_path(host),
                  class: "text-xs text-indigo-600 hover:text-indigo-500 font-medium" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-8">No hosts in this group yet.</p>
    <% end %>
  </div>

  <%= link_to "← Back to Groups", groups_path, class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
</div>
