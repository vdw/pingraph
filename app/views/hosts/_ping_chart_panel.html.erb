<div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm p-5 mb-6">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-4">
    <div>
      <h2 class="text-sm font-semibold text-gray-600 dark:text-gray-300">Latency over time</h2>
      <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5">Smoke view uses avg RTT line with min/max envelope per bucket.</p>
    </div>

    <div class="flex flex-wrap items-center gap-2">
      <div class="inline-flex rounded-lg bg-gray-100 dark:bg-gray-700 p-1">
        <% ["3h", "12h", "24h", "7d"].each do |window| %>
          <%= link_to window,
                ping_chart_host_path(host, window:, resolution: chart_resolution),
                data: { turbo_frame: "host_ping_chart" },
                class: [
                  "rounded-md px-2.5 py-1 text-xs font-medium transition-colors",
                  chart_window == window ?
                    "bg-white dark:bg-gray-800 text-indigo-700 dark:text-indigo-300 shadow-sm" :
                    "text-gray-600 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-gray-600"
                ].join(" ") %>
        <% end %>
      </div>

      <%= form_with url: ping_chart_host_path(host), method: :get, data: { turbo_frame: "host_ping_chart" }, class: "flex items-center gap-2" do |form| %>
        <%= form.hidden_field :window, value: chart_window %>
        <%= form.label :resolution, "Settings", class: "text-xs text-gray-500 dark:text-gray-400" %>
        <%= form.select :resolution,
              options_for_select([
                ["Auto", "auto"],
                ["Raw", "raw"],
                ["5m", "5m"],
                ["30m", "30m"],
                ["2h", "120m"]
              ], chart_resolution),
              {},
              {
                class: "rounded-md border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-700 text-xs text-gray-700 dark:text-gray-200",
                onchange: "this.form.requestSubmit()"
              } %>
      <% end %>
    </div>
  </div>

  <div data-chart-container class="relative h-64">
    <canvas
      data-controller="ping-chart"
      data-ping-chart-window-value="<%= chart_window %>"
      data-ping-chart-url-value="<%= pings_data_host_path(host, format: :json, window: chart_window, resolution: chart_resolution) %>">
    </canvas>
  </div>
</div>
