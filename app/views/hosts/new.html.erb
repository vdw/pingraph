<% content_for :title, "New Host" %>

<div class="max-w-xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">New Host</h1>
    <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Add a target to monitor with ICMP probes.</p>
  </div>

  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm p-6">
    <%= render "form", host: @host %>
  </div>

  <div class="mt-4">
    <%= link_to "← Back to Hosts", hosts_path, class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
  </div>
</div>
