<% content_for :title, @host.name %>

<div class="w-full max-w-5xl mx-auto">
  <%# Header %>
  <div class="flex items-start justify-between mb-6">
    <div>
      <div class="flex items-center gap-3 mb-1">
        <% status = @host.status %>
        <span class="w-3 h-3 rounded-full flex-shrink-0
          <%= status == :up ? 'bg-green-400' :
              status == :degraded ? 'bg-yellow-400' :
              status == :down ? 'bg-red-500' :
              'bg-gray-300' %>">
        </span>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @host.name %></h1>
        <span class="inline-flex items-center rounded-full bg-indigo-50 dark:bg-indigo-900/30 px-2.5 py-0.5 text-xs font-medium text-indigo-700 dark:text-indigo-300">
          <%= @host.group.name %>
        </span>
      </div>
      <p class="text-sm text-gray-500 dark:text-gray-400 font-mono pl-6"><%= @host.address %></p>
      <p class="text-xs text-gray-400 dark:text-gray-500 pl-6 mt-0.5">Polled every <%= @host.interval %> seconds</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Edit", edit_host_path(@host),
            class: "rounded-md px-3 py-2 text-sm bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 font-medium text-gray-700 dark:text-gray-200" %>
      <%= button_to "Delete", @host, method: :delete,
            class: "rounded-md px-3 py-2 text-sm bg-red-50 dark:bg-red-900/20 hover:bg-red-100 dark:hover:bg-red-900/30 text-red-700 dark:text-red-400 font-medium cursor-pointer",
            data: { turbo_confirm: "Delete #{@host.name}? This will remove all ping history." } %>
    </div>
  </div>

  <%# Smoke chart %>
  <%= turbo_frame_tag "host_ping_chart" do %>
    <%= render "ping_chart_panel", host: @host, chart_window: @chart_window, chart_resolution: @chart_resolution %>
  <% end %>

  <%# Recent pings table %>
  <div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center">
      <h2 class="text-sm font-semibold text-gray-600 dark:text-gray-300">Recent probes</h2>
      <span class="text-xs text-gray-400 dark:text-gray-500">Last 20 results</span>
    </div>
    <% if @recent_pings.any? %>
      <table class="min-w-full divide-y divide-gray-100 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700/50">
          <tr>
            <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Time</th>
            <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Avg RTT</th>
            <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Min</th>
            <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Max</th>
            <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Packet Loss</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
          <% @recent_pings.each do |ping| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30">
              <td class="py-2.5 px-4 text-sm text-gray-500 dark:text-gray-400 font-mono">
                <%= ping.recorded_at.strftime("%Y-%m-%d %H:%M:%S") %>
              </td>
              <td class="py-2.5 px-4 text-sm font-medium text-gray-900 dark:text-white">
                <%= ping.latency ? ("%.2f ms" % ping.latency) : "—" %>
              </td>
              <td class="py-2.5 px-4 text-sm text-gray-500 dark:text-gray-400">
                <%= ping.min_latency ? ("%.2f ms" % ping.min_latency) : "—" %>
              </td>
              <td class="py-2.5 px-4 text-sm text-gray-500 dark:text-gray-400">
                <%= ping.max_latency ? ("%.2f ms" % ping.max_latency) : "—" %>
              </td>
              <td class="py-2.5 px-4">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                  <%= ping.packet_loss == 0 ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400' :
                      ping.packet_loss.to_i < 50 ? 'bg-yellow-50 dark:bg-yellow-900/20 text-yellow-700 dark:text-yellow-400' :
                      'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400' %>">
                  <%= ping.packet_loss %>%
                </span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-8">No probes yet. They will appear here once Solid Queue starts polling.</p>
    <% end %>
  </div>

  <div class="mt-4">
    <%= link_to "← Back to Dashboard", root_path, class: "text-sm text-indigo-600 hover:text-indigo-500 font-medium" %>
  </div>
</div>
