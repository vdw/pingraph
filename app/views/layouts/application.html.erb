<!DOCTYPE html>
<html data-controller="dark-mode">
  <head>
    <title><%= content_for(:title) || "Pingraph" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pingraph">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-50 dark:bg-gray-950 antialiased transition-colors duration-200">
    <%# Top navigation %>
    <nav class="bg-white dark:bg-gray-900 border-b border-gray-200 dark:border-gray-700 shadow-sm">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <div class="flex items-center gap-6">
            <%= link_to root_path, class: "flex items-center gap-2 font-bold text-indigo-600 dark:text-indigo-400 text-lg" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
              </svg>
              Pingraph
            <% end %>
            <div class="hidden sm:flex items-center gap-4 text-sm">
              <%= link_to "Dashboard", root_path,
                    class: "text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 font-medium transition-colors" %>
              <%= link_to "Hosts", hosts_path,
                    class: "text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 font-medium transition-colors" %>
              <%= link_to "Groups", groups_path,
                    class: "text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 font-medium transition-colors" %>
                <%= link_to "Settings", edit_settings_path,
                  class: "text-gray-600 dark:text-gray-300 hover:text-indigo-600 dark:hover:text-indigo-400 font-medium transition-colors" %>
            </div>
          </div>
          <div class="flex items-center gap-3 text-sm">
            <%# Dark mode toggle %>
            <button data-action="dark-mode#toggle"
                    class="rounded-md p-1.5 text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors"
                    title="Toggle dark mode" aria-label="Toggle dark mode">
              <%# Sun — show in dark mode %>
              <svg class="hidden dark:block w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707.707M6.343 6.343l-.707.707M12 7a5 5 0 100 10A5 5 0 0012 7z"/>
              </svg>
              <%# Moon — show in light mode %>
              <svg class="block dark:hidden w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
              </svg>
            </button>
            <% if authenticated? %>
              <%= button_to "Sign out", session_path, method: :delete,
                    class: "text-gray-500 dark:text-gray-400 hover:text-red-600 dark:hover:text-red-400 font-medium cursor-pointer transition-colors" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <%# Flash messages %>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-3">
      <% flash.each do |type, message| %>
        <div class="rounded-md px-4 py-3 text-sm font-medium mb-3
          <%= type.to_s == 'notice' ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400' : 'bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-400' %>"
          data-controller="autohide">
          <%= message %>
        </div>
      <% end %>
    </div>

    <%# Page content %>
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <%= yield %>
    </main>
  </body>
</html>
