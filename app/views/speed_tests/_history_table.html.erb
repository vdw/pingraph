<div class="bg-white dark:bg-gray-800 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm overflow-hidden">
  <div class="px-5 py-4 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center">
    <h2 class="text-sm font-semibold text-gray-600 dark:text-gray-300">Speed test history</h2>
    <span class="text-xs text-gray-400 dark:text-gray-500">All hosts (latest first)</span>
  </div>

  <% if recent_speed_tests.any? %>
    <table class="min-w-full divide-y divide-gray-100 dark:divide-gray-700">
      <thead class="bg-gray-50 dark:bg-gray-700/50">
        <tr>
          <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Time</th>
          <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Host</th>
          <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Group</th>
          <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Bandwidth</th>
          <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Protocol</th>
          <th class="py-3 px-4 text-left text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-50 dark:divide-gray-700">
        <% recent_speed_tests.each do |speed_test| %>
          <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30">
            <td class="py-2.5 px-4 text-sm text-gray-500 dark:text-gray-400 font-mono">
              <%= (speed_test.recorded_at || speed_test.created_at).strftime("%Y-%m-%d %H:%M:%S") %>
            </td>
            <td class="py-2.5 px-4 text-sm font-medium text-gray-900 dark:text-white">
              <%= speed_test.host.name %>
            </td>
            <td class="py-2.5 px-4 text-sm text-gray-500 dark:text-gray-400">
              <%= speed_test.host.group.name %>
            </td>
            <td class="py-2.5 px-4 text-sm font-medium text-gray-900 dark:text-white">
              <%= speed_test.bandwidth_mbps ? ("%.2f Mbps" % speed_test.bandwidth_mbps) : "-" %>
            </td>
            <td class="py-2.5 px-4 text-sm text-gray-500 dark:text-gray-400 uppercase">
              <%= speed_test.protocol %>
            </td>
            <td class="py-2.5 px-4 text-sm">
              <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                <%= speed_test.completed? ? 'bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-400' : 'bg-indigo-50 dark:bg-indigo-900/30 text-indigo-700 dark:text-indigo-300' %>">
                <%= speed_test.status.humanize %>
              </span>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="text-sm text-gray-400 dark:text-gray-500 text-center py-8">No speed tests yet. Run one to populate history.</p>
  <% end %>
</div>
